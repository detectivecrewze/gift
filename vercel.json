{
  "rewrites": [
    {
      "source": "/",
      "destination": "/arcade/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/$1"
    },
    {
      "source": "/generator",
      "destination": "/generator/index.html"
    },
    {
      "source": "/generator/(.*)",
      "destination": "/generator/$1"
    },
    {
      "source": "/(style\\.css|script\\.js|config\\.js)",
      "destination": "/arcade/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/arcade/assets/$1"
    },
    {
      "source": "/rooms/(.*)",
      "destination": "/arcade/rooms/$1"
    },
    {
      "source": "/:id",
      "destination": "/arcade/index.html?id=$id"
    }
  ]
}
